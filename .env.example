PORT=3000

# Public API token used by clients such as iOS Shortcuts.
OPEN_DOOR_TOKEN=change-me

# Doorlink device HTTP endpoint. This is usually the indoor monitor IP with port 8080.
DOORLINK_URL=http://192.168.161.61:8080/

# SIP values sent to the Doorlink device for unlock.
DOORLINK_FROM=1-160106010@192.168.161.61:14301
DOORLINK_TO=160100000@192.168.161.1:14301
DOORLINK_FAMILY=1

# Optional request timeout in milliseconds.
DOORLINK_TIMEOUT_MS=3000
